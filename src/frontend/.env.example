# Frontend Environment Variables
# Copy this file to .env.local for local development

# API Configuration
# Development: Local backend
VITE_API_BASE_URL=http://localhost:3000/api/v1
# Production: Render.com backend  
# VITE_API_BASE_URL=https://cut-grc-free.onrender.com/api/v1
VITE_API_TIMEOUT=30000

# Application Configuration
VITE_APP_NAME="CUT GRC Platform"
VITE_APP_VERSION=1.0.0
VITE_APP_ENVIRONMENT=development

# Authentication
VITE_AUTH_TOKEN_KEY=auth_token
VITE_AUTH_REFRESH_TOKEN_KEY=auth_refresh_token
VITE_AUTH_USER_KEY=auth_user

# Feature Flags
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_DEBUG=true
VITE_ENABLE_MOCK_API=true

# External Services
VITE_SENTRY_DSN=
VITE_GOOGLE_ANALYTICS_ID=

# African Regional Settings
VITE_DEFAULT_LANGUAGE=en
VITE_SUPPORTED_LANGUAGES=en,fr,pt,sw,zu,xh
VITE_DEFAULT_CURRENCY=ZAR
VITE_DEFAULT_TIMEZONE=Africa/Johannesburg

# UI Configuration
VITE_THEME_MODE=light
VITE_PRIMARY_COLOR=#4B0082
VITE_SECONDARY_COLOR=#CC7722

# Build Configuration
VITE_BUILD_SOURCEMAP=true
VITE_BUILD_MINIFY=true