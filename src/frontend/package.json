{
  "name": "cut-grc-frontend",
  "version": "1.0.0",
  "private": true,
  "description": "CUT GRC Platform Frontend Application",
  "type": "module",
  "scripts": {
    "diagnostics": "echo "Open http://localhost:5173/diagnostic-tools/ in your browser"",
    "postbuild": "node copy-diagnostic-tools.js",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint src/**/*.{ts,tsx}",
    "lint:fix": "eslint src/**/*.{ts,tsx} --fix",
    "format": "prettier --write src/**/*.{ts,tsx}",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build",
    "check": "npm run lint && npm run type-check && npm test",
    "docker:build": "docker build -t cut-grc-frontend .",
    "docker:run": "docker run -p 5173:80 cut-grc-frontend"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.14.0",
    "@reduxjs/toolkit": "^1.9.5",
    "react-redux": "^8.1.1",
    "@mui/material": "^5.13.2",
    "@emotion/react": "^11.11.1",
    "@emotion/styled": "^11.11.0",
    "@mui/icons-material": "^5.13.2",
    "@mui/x-data-grid": "^6.6.0",
    "@mui/x-date-pickers": "^6.6.0",
    "date-fns": "^2.30.0",
    "axios": "^1.4.0",
    "socket.io-client": "^4.6.1",
    "recharts": "^2.7.0",
    "i18next": "^23.2.6",
    "react-i18next": "^13.0.2",
    "react-hook-form": "^7.45.1",
    "@hookform/resolvers": "^3.1.1",
    "zod": "^3.21.4",
    "notistack": "^3.0.0",
    "react-query": "^3.39.3"
  },
  "devDependencies": {
    "@types/react": "^18.2.6",
    "@types/react-dom": "^18.2.4",
    "@typescript-eslint/eslint-plugin": "^5.59.11",
    "@typescript-eslint/parser": "^5.59.11",
    "@vitejs/plugin-react": "^4.0.0",
    "eslint": "^8.42.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.1",
    "prettier": "^2.8.8",
    "typescript": "^5.1.3",
    "vite": "^4.3.9",
    "jest": "^29.5.0",
    "@types/jest": "^29.5.2",
    "ts-jest": "^29.1.0",
    "@testing-library/react": "^14.0.0",
    "@testing-library/jest-dom": "^5.16.5",
    "@testing-library/user-event": "^14.4.3",
    "@storybook/react": "^7.0.24",
    "@storybook/react-vite": "^7.0.24",
    "@storybook/addon-essentials": "^7.0.24",
    "@storybook/addon-interactions": "^7.0.24",
    "@storybook/addon-links": "^7.0.24",
    "@storybook/testing-library": "^0.2.0",
    "storybook": "^7.0.24"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}