{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": [
      "ES2022"
    ],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "removeComments": true,
    "noFallthroughCasesInSwitch": true,
    "moduleResolution": "node10",
    "allowSyntheticDefaultImports": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "ignoreDeprecations": "6.0"
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "**/*.test.ts",
    "**/*.spec.ts",
    "**/seeds/**",
    "**/tests/**",
    "**/security-test.ts",
    "**/health/**",
    "**/municipal/**",
    "**/documents/**",
    "**/ad-integration/**",
    "**/validation.middleware.ts",
    "**/security.middleware.ts",
    "**/database-sqlite.ts"
  ]
}