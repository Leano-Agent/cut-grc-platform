{
  "name": "cut-grc-backend",
  "version": "1.0.0",
  "description": "CUT GRC Platform Backend API",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon --exec ts-node src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write src/**/*.ts",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:integration": "jest --config jest.integration.config.js",
    "migrate:up": "ts-node src/database/migrations/run-migrations.ts up",
    "migrate:down": "ts-node src/database/migrations/run-migrations.ts down",
    "seed:dev": "ts-node src/database/seeds/seed-dev.ts",
    "docs:generate": "ts-node src/docs/generate-openapi.ts",
    "docs:serve": "swagger-ui-express dist/openapi.json",
    "check": "npm run lint && npm run type-check && npm test",
    "docker:build": "docker build -t cut-grc-backend .",
    "docker:run": "docker run -p 3000:3000 cut-grc-backend"
  },
  "keywords": [
    "grc",
    "risk-management",
    "compliance",
    "enterprise",
    "nodejs",
    "typescript"
  ],
  "author": "CUT GRC Development Team",
  "license": "MIT",
  "dependencies": {
    "@socket.io/redis-adapter": "^8.3.0",
    "@types/sequelize": "^4.28.20",
    "aws-sdk": "^2.1394.0",
    "bcrypt": "^5.1.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "express-openapi-validator": "^5.0.0",
    "express-rate-limit": "^6.10.0",
    "express-slow-down": "^1.5.0",
    "express-validator": "^7.0.1",
    "helmet": "^7.0.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.0",
    "ldapjs": "^3.0.2",
    "multer": "^1.4.5-lts.1",
    "multer-s3": "^3.0.1",
    "nodemailer": "^6.9.3",
    "passport": "^0.6.0",
    "passport-jwt": "^4.0.1",
    "passport-ldapauth": "^3.0.0",
    "passport-local": "^1.0.0",
    "pg": "^8.11.0",
    "redis": "^4.6.7",
    "sequelize": "^6.37.8",
    "socket.io": "^4.6.1",
    "socket.io-redis": "^6.1.1",
    "sqlite3": "^5.1.6",
    "swagger-ui-express": "^4.6.3",
    "winston": "^3.9.0",
    "zod": "^3.21.4"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.0",
    "@types/cors": "^2.8.13",
    "@types/express": "^4.17.17",
    "@types/faker": "^5.5.9",
    "@types/ioredis": "^4.28.10",
    "@types/jest": "^29.5.2",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/ldapjs": "^2.2.5",
    "@types/multer": "^1.4.7",
    "@types/node": "^20.3.1",
    "@types/nodemailer": "^6.4.9",
    "@types/passport": "^1.0.14",
    "@types/passport-jwt": "^3.0.10",
    "@types/passport-local": "^1.0.38",
    "@types/supertest": "^2.0.12",
    "@typescript-eslint/eslint-plugin": "^5.59.11",
    "@typescript-eslint/parser": "^5.59.11",
    "eslint": "^8.42.0",
    "faker": "^5.5.3",
    "jest": "^29.5.0",
    "nodemon": "^2.0.22",
    "prettier": "^2.8.8",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.1",
    "typescript": "^5.1.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=9.0.0"
  }
}
