# Backend Environment Variables
# Copy this file to .env and fill in the values

# Application
NODE_ENV=development
PORT=3000

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/cut_grc

# Redis
REDIS_URL=redis://localhost:6379

# Authentication
JWT_SECRET=your_jwt_secret_key_here_change_in_production

# CORS - SECURITY: List specific allowed origins separated by commas
CORS_ORIGIN=http://localhost:5173,https://cut-grc-frontend.vercel.app,https://cut-grc-emergency.vercel.app,https://cut-grc-emergency-v2.vercel.app

# API
API_PREFIX=/api/v1

# Logging
LOG_LEVEL=info

# AWS Configuration (African Sovereignty: Use African regions)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=af-south-1
AWS_S3_BUCKET=

# Email (Production: Use African email services when available)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASSWORD=

# Monitoring
SENTRY_DSN=

# Additional African Sovereignty Configurations
# AFRICAN_PAYMENT_GATEWAY_API_KEY=
# AFRICAN_SMS_PROVIDER_API_KEY=
# AFRICAN_CDN_ENDPOINT=